# Copy to `.env` and fill in. `.env` is gitignored — never commit real tokens.
#
# Loaded by the deploy flow via Node's --env-file, e.g.:
#   node --env-file=.env scripts/build_site.mjs

# Mapbox public token (pk....) — baked into web/config.js at build time.
# Restrict it to https://anothersava.com/* in the Mapbox dashboard.
MAPBOX_TOKEN=

# Cloudflare API token with: Account → Cloudflare Pages → Edit,
# and Zone → DNS → Edit (scoped to the anothersava.com zone).
CLOUDFLARE_API_TOKEN=

# Cloudflare account ID (Dashboard → any domain → Overview, right sidebar).
CLOUDFLARE_ACCOUNT_ID=
